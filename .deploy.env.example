# Copy this file to .deploy.env and fill in your own values.
# .deploy.env is git-ignored and stays local.

# SSH host (alias from ~/.ssh/config or user@host)
REMOTE="user@your-server"

# Absolute path of the site webroot on the server
WEBROOT="/var/www/example.com"

# Public API endpoint used by the browser chat widget
PUBLIC_RAG_API_URL="https://api.example.com"

# RAG service settings are configured separately on the server.
