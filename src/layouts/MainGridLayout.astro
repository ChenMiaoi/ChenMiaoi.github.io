---
import BackToTop from "@components/control/BackToTop.astro";
import CardCounts from "@components/CardCounts.astro";
import ParaComments from "@components/ParaComments.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import SeriesSidebar from "@components/SeriesSidebar.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface SeriesSidebarPost {
	title: string;
	url: string;
	current: boolean;
}

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	sidebar?: "default" | "series" | "none";
	seriesSidebar?: {
		seriesTitle: string;
		seriesSlug: string;
		posts: SeriesSidebarPost[];
	} | null;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	sidebar = "default",
	seriesSidebar,
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;
const showProfileSidebar = sidebar === "default";
const showSeriesSidebar = sidebar === "series" && !!seriesSidebar;
const showSidebar = showProfileSidebar || showSeriesSidebar;
const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";

/* Show the TOC as a permanent third column on post pages (xl and up) */
const showToc = siteConfig.toc.enable && headings.length > 0;

// Grid column template per sidebar mode. `none` (non-series post) drops the
// 17.5rem sidebar track so the article takes the full page width.
const gridColClass = showSidebar
	? showToc
		? "grid-cols-[17.5rem_auto] xl:grid-cols-[17.5rem_minmax(0,1fr)_14rem]"
		: "grid-cols-[17.5rem_auto]"
	: showToc
		? "grid-cols-1 xl:grid-cols-[minmax(0,1fr)_14rem]"
		: "grid-cols-1";
const mainColClass = showSidebar ? "col-span-2 lg:col-span-1" : "col-span-1";

---
<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>
<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar lang={lang}></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class:list={["transition duration-700 w-full left-0 right-0 grid grid-rows-[auto_1fr_auto] lg:grid-rows-[auto] mx-auto gap-4 px-0 md:px-4", gridColClass]}
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            <!-- Swapped by Swup on navigation: display:contents keeps the
                 sidebar as a direct grid item while letting the wrapper exist
                 (empty) on sidebar-less pages. -->
            <div id="sidebar-wrapper" class="contents">
                {showProfileSidebar && <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings} lang={lang}></SideBar>}
                {showSeriesSidebar && seriesSidebar && <SeriesSidebar seriesTitle={seriesSidebar.seriesTitle} seriesSlug={seriesSidebar.seriesSlug} posts={seriesSidebar.posts} lang={lang} />}
            </div>

            <main id="swup-container" class:list={["transition-swup-fade overflow-hidden", mainColClass]}>
                <div id="content-wrapper" class="onload-animation" data-sidebar-mode={sidebar} data-show-toc={showToc ? "1" : "0"}>
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer lang={lang}></Footer>
                    </div>
                </div>
            </main>

            <!-- TOC: permanent third column on post pages (xl and up). The wrapper must exist on
                 every page because Swup only swaps the inner #toc element during navigation. -->
            <div id="toc-wrapper" class:list={["hidden xl:block transition", {"toc-hide": siteConfig.banner.enable}]}>
                <div id="toc-inner-wrapper" class="sticky top-[5.5rem] max-h-[calc(100vh-7rem)] overflow-y-auto overflow-x-hidden hide-scrollbar">
                    {showToc && <div id="toc" class="w-full transition-swup-fade rounded-[var(--radius-large)] bg-[var(--card-bg)] p-2">
                        <TOC headings={headings}></TOC>
                    </div>}
                    {!showToc && <div id="toc"></div>}
                </div>
            </div>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer lang={lang}></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>
<CardCounts />
<ParaComments />
</Layout>

<script>
	import { siteConfig } from "../config";

	const walineLangMap: Record<string, string> = {
		"zh-CN": "zh-CN",
		"zh-TW": "zh-TW",
		en: "en-US",
		ja: "jp-JP",
	};

	async function initWaline() {
		const el = document.getElementById("waline");
		if (!el || !siteConfig.comment?.enable) return;
		await import("@waline/client/style");
		const { init, pageviewCount } = await import("@waline/client");
		init({
			el,
			serverURL: siteConfig.comment.serverURL,
			path: window.location.pathname,
			lang: walineLangMap[document.documentElement.lang] ?? "en-US",
			dark: "html.dark",
			reaction: true,
		});
		// Record a page view for this post (counter feeds the home cards).
		pageviewCount({
			serverURL: siteConfig.comment.serverURL,
			path: window.location.pathname,
			update: true,
		});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initWaline);
	} else {
		initWaline();
	}

	// Swup swaps only main/#toc/#sidebar-wrapper, so the sidebar region and
	// #main-grid's column template must be re-derived on every navigation.
	// The target page's mode travels on the swapped #content-wrapper.
	const GRID_BASE =
		"transition duration-700 w-full left-0 right-0 grid grid-rows-[auto_1fr_auto] lg:grid-rows-[auto] mx-auto gap-4 px-0 md:px-4";
	const gridCols = (mode: string, toc: boolean): string =>
		mode === "none"
			? toc
				? "grid-cols-1 xl:grid-cols-[minmax(0,1fr)_14rem]"
				: "grid-cols-1"
			: toc
				? "grid-cols-[17.5rem_auto] xl:grid-cols-[17.5rem_minmax(0,1fr)_14rem]"
				: "grid-cols-[17.5rem_auto]";
	function syncMainGrid(): void {
		const grid = document.getElementById("main-grid");
		const cw = document.getElementById("content-wrapper");
		if (!grid || !cw) return;
		grid.className = `${GRID_BASE} ${gridCols(cw.dataset.sidebarMode ?? "default", cw.dataset.showToc === "1")}`;
	}

	// Swup swaps only the main/#toc containers without re-running page
	// scripts, so Waline must be re-initialized on every navigation.
	// Register the hook exactly once and wait for window.swup if needed.
	const w = window as any;
	if (!w.__walineSwupHooked) {
		w.__walineSwupHooked = true;
		const tryHook = (n = 0): void => {
			if (w.swup?.hooks) {
				w.swup.hooks.on("page:view", initWaline);
				w.swup.hooks.on("page:view", syncMainGrid);
			} else if (n < 50) {
				setTimeout(() => tryHook(n + 1), 100);
			}
		};
		tryHook();
	}
</script>
