---
import SeriesDetailPage from "@components/pages/SeriesDetailPage.astro";
import { getSeriesAncestors, getSeriesTree } from "@utils/content-utils";

export async function getStaticPaths() {
	const tree = await getSeriesTree("ja");
	return [...tree.nodes.values()].map((node) => ({
		params: { slug: node.slug },
		props: {
			node,
			ancestors: getSeriesAncestors(tree, node.slug).map((n) => ({
				slug: n.slug,
				title: n.title,
			})),
		},
	}));
}

const { node, ancestors } = Astro.props;
---

<SeriesDetailPage node={node} ancestors={ancestors} lang="ja" />
