---
import PostDetailPage from "@components/pages/PostDetailPage.astro";
import {
	buildSeriesNav,
	getSeriesTree,
	getSortedPosts,
} from "@utils/content-utils";

export async function getStaticPaths() {
	const pad = (n: number) => String(n).padStart(2, "0");
	const blogEntries = await getSortedPosts("zh_TW");
	const seriesTree = await getSeriesTree("zh_TW");
	return blogEntries.map((entry) => {
		const d = new Date(entry.data.published);
		return {
			params: {
				year: String(d.getUTCFullYear()),
				month: pad(d.getUTCMonth() + 1),
				day: pad(d.getUTCDate()),
				slug: entry.slug,
			},
			props: { entry, seriesNav: buildSeriesNav(entry, seriesTree, "zh_TW") },
		};
	});
}

const { entry, seriesNav } = Astro.props;
---

<PostDetailPage entry={entry} seriesNav={seriesNav} lang="zh_TW" />
