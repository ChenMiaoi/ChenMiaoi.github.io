---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	type SeriesNode,
	flattenSeriesPosts,
	seriesItems,
} from "@utils/content-utils";
import { getPostUrlBySlug, url } from "@utils/url-utils";
import { formatDateTime } from "@utils/date-utils";
import { Icon } from "astro-icon/components";

interface Props {
	node: SeriesNode;
	ancestors?: { slug: string; title: string }[]; // root … parent
	lang?: string;
}

const { node, ancestors = [], lang } = Astro.props;

const items = seriesItems(node);
// Only direct posts get sequence numbers; sub-series rows show an icon.
let postNo = 0;
const numbered = items.map((item) => ({
	...item,
	no: item.kind === "post" ? ++postNo : 0,
}));
const totalPosts = flattenSeriesPosts(node).length;
---

<MainGridLayout title={node.title} description={node.description} lang={lang}>
    <div class="card-base p-6 md:p-9 mb-4 onload-animation">
        {ancestors.length > 0 && (
            <nav class="mb-2 flex flex-wrap items-center gap-1 text-sm text-black/40 dark:text-white/40">
                {ancestors.map((a) => (
                    <>
                        <a href={url(`/series/${a.slug}/`, lang)} class="hover:text-[var(--primary)] transition">
                            {a.title}
                        </a>
                        <Icon name="material-symbols:chevron-right-rounded" class="text-base shrink-0" />
                    </>
                ))}
            </nav>
        )}
        <div class="flex items-center gap-2 mb-2">
            <Icon name="material-symbols:collections-bookmark-outline-rounded"
                  class="text-2xl text-[var(--primary)]" />
            <h1 class="font-bold text-2xl md:text-3xl text-black/90 dark:text-white/90">{node.title}</h1>
        </div>
        {node.description && (
            <p class="text-black/60 dark:text-white/60 mb-3">{node.description}</p>
        )}
        <div class="text-sm text-black/30 dark:text-white/30">
            {totalPosts} {i18n(totalPosts === 1 ? I18nKey.postCount : I18nKey.postsCount, lang)}
            {node.children.length > 0 && ` · ${node.children.length} ${i18n(node.children.length === 1 ? I18nKey.subSeriesCount : I18nKey.subSeriesCountPlural, lang)}`}
        </div>
    </div>

    <div class="card-base px-6 md:px-9 py-4 onload-animation">
        <ol class="divide-y divide-dashed divide-[var(--line-divider)]">
            {numbered.map((item) => (
                <li>
                    {item.kind === "series" ? (
                        <a href={url(`/series/${item.node.slug}/`, lang)}
                           class="group flex items-center gap-4 py-4 transition">
                            <Icon name="material-symbols:collections-bookmark-outline-rounded"
                                  class="shrink-0 text-xl text-[var(--primary)]" />
                            <span class="grow font-bold text-black/80 dark:text-white/80 group-hover:text-[var(--primary)] transition">
                                {item.node.title}
                            </span>
                            <span class="shrink-0 text-sm text-black/30 dark:text-white/30">
                                {flattenSeriesPosts(item.node).length} {i18n(I18nKey.postsCount, lang)}
                            </span>
                        </a>
                    ) : (
                        <a href={getPostUrlBySlug(item.post.slug, item.post.published, lang)}
                           class="group flex items-center gap-4 py-4 transition">
                            <span class="shrink-0 w-8 text-center font-bold text-black/20 dark:text-white/20 group-hover:text-[var(--primary)] transition">
                                {String(item.no).padStart(2, "0")}
                            </span>
                            <span class="grow font-medium text-black/80 dark:text-white/80 group-hover:text-[var(--primary)] transition">
                                {item.post.title}
                            </span>
                            <span class="shrink-0 text-sm text-black/30 dark:text-white/30">
                                {formatDateTime(item.post.published)}
                            </span>
                        </a>
                    )}
                </li>
            ))}
        </ol>
    </div>
</MainGridLayout>
