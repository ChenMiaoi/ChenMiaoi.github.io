---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import type { SeriesInfo } from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { Icon } from "astro-icon/components";

interface Props {
	info: SeriesInfo;
	lang?: string;
}

const { info, lang } = Astro.props;
---

<MainGridLayout title={info.title} description={info.description} lang={lang}>
    <div class="card-base p-6 md:p-9 mb-4 onload-animation">
        <div class="flex items-center gap-2 mb-2">
            <Icon name="material-symbols:collections-bookmark-outline-rounded"
                  class="text-2xl text-[var(--primary)]" />
            <h1 class="font-bold text-2xl md:text-3xl text-black/90 dark:text-white/90">{info.title}</h1>
        </div>
        {info.description && (
            <p class="text-black/60 dark:text-white/60 mb-3">{info.description}</p>
        )}
        <div class="text-sm text-black/30 dark:text-white/30">{info.posts.length} {i18n(info.posts.length === 1 ? I18nKey.postCount : I18nKey.postsCount, lang)}</div>
    </div>

    <div class="card-base px-6 md:px-9 py-4 onload-animation">
        <ol class="divide-y divide-dashed divide-[var(--line-divider)]">
            {info.posts.map((post, i) => (
                <li>
                    <a href={getPostUrlBySlug(post.slug, post.published, lang)}
                       class="group flex items-center gap-4 py-4 transition">
                        <span class="shrink-0 w-8 text-center font-bold text-black/20 dark:text-white/20 group-hover:text-[var(--primary)] transition">
                            {String(i + 1).padStart(2, "0")}
                        </span>
                        <span class="grow font-medium text-black/80 dark:text-white/80 group-hover:text-[var(--primary)] transition">
                            {post.title}
                        </span>
                        <span class="shrink-0 text-sm text-black/30 dark:text-white/30">
                            {formatDateToYYYYMMDD(post.published)}
                        </span>
                    </a>
                </li>
            ))}
        </ol>
    </div>
</MainGridLayout>
