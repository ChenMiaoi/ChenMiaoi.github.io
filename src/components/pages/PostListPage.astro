---
import type { Page } from "astro";
import Pagination from "@components/control/Pagination.astro";
import PostPage from "@components/PostPage.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

interface Props {
	page: Page;
	lang?: string;
}

const { page, lang } = Astro.props;

const len = page.data.length;
---

<MainGridLayout lang={lang}>
    <PostPage page={page} lang={lang}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} lang={lang} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>
