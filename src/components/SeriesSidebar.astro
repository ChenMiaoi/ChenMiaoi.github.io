---
import { Icon } from "astro-icon/components";

interface SidebarItem {
	kind: "post" | "series";
	title: string;
	url: string;
	current?: boolean;
	slug?: string;
}

interface Props {
	seriesTitle: string; // leaf series the post belongs to
	seriesSlug: string;
	ancestors?: { slug: string; title: string }[]; // root … parent
	items: SidebarItem[];
	lang?: string;
}

const { seriesTitle, seriesSlug, ancestors = [], items } = Astro.props;
// Only posts get sequence numbers; sub-series rows show a bookmark icon.
let postNo = 0;
const numbered = items.map((item) => ({
	...item,
	no: item.kind === "post" ? ++postNo : 0,
}));
---
<div id="series-sidebar" class="card-base p-4 w-full mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] self-start lg:sticky lg:top-4 onload-animation">
    {ancestors.length > 0 && (
        <nav class="mb-2 flex flex-wrap items-center gap-1 text-xs text-black/40 dark:text-white/40">
            {ancestors.map((a) => (
                <>
                    <a href={`/series/${a.slug}/`} class="hover:text-[var(--primary)] transition truncate max-w-full">
                        {a.title}
                    </a>
                    <Icon name="material-symbols:chevron-right-rounded" class="text-sm shrink-0" />
                </>
            ))}
        </nav>
    )}
    <a href={`/series/${seriesSlug}/`} class="block font-bold text-black/80 dark:text-white/80 hover:text-[var(--primary)] transition mb-3">
        {seriesTitle}
    </a>
    <ol class="flex flex-col gap-1">
        {numbered.map((item) => (
            <li>
                <a href={item.url}
                   aria-current={item.current ? "page" : undefined}
                   class:list={["flex items-center rounded-lg px-3 py-2 text-sm transition", item.current ? "bg-[var(--primary)]/10 text-[var(--primary)] font-bold" : "text-black/60 dark:text-white/60 hover:bg-black/5 dark:hover:bg-white/5"]}>
                    {item.kind === "series" ? (
                        <Icon name="material-symbols:collections-bookmark-outline-rounded" class="mr-2 text-base shrink-0 opacity-70" />
                    ) : (
                        <span class="mr-2 text-xs opacity-60">{String(item.no).padStart(2, "0")}</span>
                    )}
                    <span class="truncate">{item.title}</span>
                </a>
            </li>
        ))}
    </ol>
</div>
