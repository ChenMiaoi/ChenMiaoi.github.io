---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
---

{/* Wrapper structure matches TOC scroll-spy expectations: the anchor must be the
    first element child so `section.children[0].id` resolves to "comments". */}
<div><div id="comments" class="scroll-mt-24"></div><div class="card-base px-6 md:px-9 py-6 mb-4 w-full">
    <div class="font-bold text-lg mb-4 text-black/90 dark:text-white/90">
        {i18n(I18nKey.comments)}
    </div>
    <div id="waline"></div>
</div></div>
