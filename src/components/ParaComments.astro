---
/**
 * ParaComments — self-hosted paragraph-level comments for post pages.
 *
 * Backend: https://api.nyachen.cn/pc (see the API contract in the script
 * below). The component renders nothing visible itself: the marker <div>
 * only exists to carry this component's Astro scoped-style attribute
 * (data-astro-cid-*). Astro's scoped CSS transform appends the scope
 * attribute selector to every compound selector, so the script reads the
 * attribute name off the marker and stamps it onto every DOM node it
 * creates or annotates — that is what lets the scoped <style> rules below
 * match runtime-injected nodes.
 *
 * Lifecycle mirrors the Waline init in src/layouts/MainGridLayout.astro:
 * run once on load, then re-run on every Swup "page:view" (Swup swaps the
 * main/#toc containers without re-executing page scripts).
 */
---

<div data-para-comments hidden></div>

<script>
	const API_BASE = "https://api.nyachen.cn/pc";

	const STRINGS = {
		"zh-CN": {
			commentPara: "评论本段",
			comment: "条评论",
			comments: "条评论",
			nickname: "昵称",
			contact: "联系方式（可选）",
			writeComment: "写下你的评论…",
			submit: "提交",
			postComment: "发表评论",
			tooFast: "操作太频繁，请稍后再试",
			loadFailed: "加载失败",
			networkError: "网络错误",
			noComments: "暂无评论",
			close: "关闭",
		},
		"zh-TW": {
			commentPara: "評論本段",
			comment: "條評論",
			comments: "條評論",
			nickname: "暱稱",
			contact: "聯絡方式（可選）",
			writeComment: "寫下你的評論…",
			submit: "提交",
			postComment: "發表評論",
			tooFast: "操作太頻繁，請稍後再試",
			loadFailed: "載入失敗",
			networkError: "網路錯誤",
			noComments: "暫無評論",
			close: "關閉",
		},
		en: {
			commentPara: "Comment on this paragraph",
			comment: "comment",
			comments: "comments",
			nickname: "Nickname",
			contact: "Contact (optional)",
			writeComment: "Write a comment…",
			submit: "Submit",
			postComment: "Post comment",
			tooFast: "Too many comments, please slow down",
			loadFailed: "Failed to load",
			networkError: "Network error",
			noComments: "No comments yet",
			close: "Close",
		},
		ja: {
			commentPara: "この段落にコメント",
			comment: "件のコメント",
			comments: "件のコメント",
			nickname: "ニックネーム",
			contact: "連絡先（任意）",
			writeComment: "コメントを書く…",
			submit: "送信",
			postComment: "コメントを投稿",
			tooFast: "コメントが多すぎます。しばらく待ってから再度お試しください",
			loadFailed: "読み込みに失敗しました",
			networkError: "ネットワークエラー",
			noComments: "コメントはまだありません",
			close: "閉じる",
		},
	};

	// Re-evaluated on every init: a Swup navigation may cross languages
	// (zh -> en ...) without reloading this script.
	const docLang = () =>
		(document.documentElement.lang || "en").replace("_", "-");
	let pageLang = docLang();
	let T = STRINGS[pageLang] || STRINGS.en;
	// English needs a plural form, CJK languages use "<n><unit>".
	const countText = (n) =>
		pageLang === "en"
			? `${n} ${n === 1 ? T.comment : T.comments}`
			: `${n}${T.comments}`;

	const ICON_COMMENT =
		'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>';
	const ICON_CLOSE =
		'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block"><path d="M18 6 6 18"/><path d="M6 6l12 12"/></svg>';

	// ---------------------------------------------------------------------
	// Scope attribute plumbing (see the component comment above)
	// ---------------------------------------------------------------------
	let scopeAttr = "";
	let scopeClass = "";

	function detectScopeAttr() {
		scopeAttr = "";
		scopeClass = "";
		const marker = document.querySelector("[data-para-comments]");
		if (!marker) return;
		for (const attr of marker.attributes) {
			if (attr.name.startsWith("data-astro-cid-")) {
				scopeAttr = attr.name;
				return;
			}
		}
		// fallback in case Astro ever switches to class-based scoping
		for (const cls of Array.from(marker.classList)) {
			if (cls.startsWith("astro-")) {
				scopeClass = cls;
				return;
			}
		}
	}

	function stamp(node) {
		if (scopeAttr) node.setAttribute(scopeAttr, "");
		else if (scopeClass) node.classList.add(scopeClass);
		return node;
	}

	function el(tag, className, text) {
		const node = stamp(document.createElement(tag));
		if (className) node.className = className;
		if (text != null) node.textContent = text;
		return node;
	}

	// ---------------------------------------------------------------------
	// Anchoring: 32-bit FNV-1a over the normalized paragraph text, base36.
	// ---------------------------------------------------------------------
	function fnv1a(str) {
		let h = 0x811c9dc5;
		for (let i = 0; i < str.length; i++) {
			h ^= str.charCodeAt(i);
			h = Math.imul(h, 0x01000193);
		}
		return (h >>> 0).toString(36);
	}

	function normalize(text) {
		return text.replace(/\s+/g, " ").trim();
	}

	function fmtDate(value) {
		if (value == null || value === "") return "";
		let d;
		if (typeof value === "number" || /^\d+$/.test(String(value))) {
			const n = Number(value);
			d = new Date(n < 1e12 ? n * 1000 : n); // seconds or milliseconds
		} else {
			// tolerate "YYYY-MM-DD HH:MM:SS" (Safari rejects the space form)
			d = new Date(String(value).replace(" ", "T"));
		}
		if (Number.isNaN(d.getTime())) return String(value);
		const p = (x) => String(x).padStart(2, "0");
		return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())} ${p(d.getHours())}:${p(d.getMinutes())}`;
	}

	// ---------------------------------------------------------------------
	// Per-page state. initParaComments() resets everything on each run, so
	// nothing leaks between Swup navigations. `gen` invalidates async work
	// started by a previous page/init.
	// ---------------------------------------------------------------------
	let gen = 0;
	let counts = null; // {anchor: n} | null (null = not loaded / failed)
	let commentsCache = null; // {anchor: Comment[]} | null
	let commentsPromise = null;
	let btnByAnchor = new Map();
	let panelEl = null;
	let overlayEl = null;
	let openAnchor = null;
	let openCountLine = null;

	function updateBadge(anchor) {
		const btn = btnByAnchor.get(anchor);
		if (!btn) return;
		const n = (counts && counts[anchor]) || 0;
		let badge = btn.querySelector(".pc-badge");
		if (n > 0) {
			if (!badge) {
				badge = el("span", "pc-badge");
				btn.appendChild(badge);
			}
			badge.textContent = String(n);
			btn.classList.add("pc-btn--has");
		} else {
			if (badge) badge.remove();
			btn.classList.remove("pc-btn--has");
		}
		if (openAnchor === anchor && openCountLine) {
			openCountLine.textContent = countText(n);
		}
	}

	// Full comment payload, fetched lazily on first panel open and cached
	// for the rest of the page's lifetime. Resolves to false on failure
	// (the caller then shows the load-error message); never rejects.
	function ensureComments() {
		if (commentsCache) return Promise.resolve(true);
		if (commentsPromise) return commentsPromise;
		const myGen = gen;
		commentsPromise = fetch(
			`${API_BASE}/comments?path=${encodeURIComponent(window.location.pathname)}`,
			{ credentials: "omit" },
		)
			.then((res) => {
				if (!res.ok) throw new Error(String(res.status));
				return res.json();
			})
			.then((data) => {
				if (myGen !== gen) return false;
				commentsCache = (data && data.comments) || {};
				// The full response carries counts too — use it to (re)fill
				// badges if the init-time counts fetch failed or is stale.
				if (data && data.counts) {
					counts = data.counts;
					for (const anchor of Object.keys(counts)) updateBadge(anchor);
				}
				return true;
			})
			.catch(() => {
				commentsCache = null;
				return false;
			})
			.finally(() => {
				commentsPromise = null;
			});
		return commentsPromise;
	}

	function buildCommentEl(c) {
		const item = el("div", "pc-item");
		const meta = el("div", "pc-item-meta");
		// nicks/content are HTML-escaped server-side already; render as text.
		meta.appendChild(el("span", "pc-nick", c.nick == null ? "" : String(c.nick)));
		meta.appendChild(el("span", "pc-date", fmtDate(c.created_at)));
		item.appendChild(meta);
		item.appendChild(
			el("div", "pc-item-content", c.content == null ? "" : String(c.content)),
		);
		return item;
	}

	function renderCommentsInto(list, anchor) {
		list.innerHTML = "";
		const items = (commentsCache && commentsCache[anchor]) || [];
		if (!items.length) {
			list.appendChild(el("div", "pc-status", T.noComments));
			return;
		}
		for (const c of items) list.appendChild(buildCommentEl(c));
	}

	function closePanel() {
		if (!panelEl && !overlayEl) return;
		const p = panelEl;
		const o = overlayEl;
		panelEl = null;
		overlayEl = null;
		openAnchor = null;
		openCountLine = null;
		document.body.style.overflow = "";
		if (p) p.classList.remove("pc-open");
		if (o) o.classList.remove("pc-open");
		setTimeout(() => {
			if (p) p.remove();
			if (o) o.remove();
		}, 300);
	}

	function openPanel(anchor, paraText) {
		closePanel();
		openAnchor = anchor;
		const myGen = gen;

		overlayEl = el("div", "pc-overlay");
		overlayEl.addEventListener("click", closePanel);

		panelEl = el("div", "pc-panel");
		panelEl.setAttribute("role", "dialog");
		panelEl.setAttribute("aria-modal", "true");
		panelEl.setAttribute("aria-label", T.postComment);

		const head = el("div", "pc-panel-head");
		const excerpt =
			paraText.length > 80 ? `${paraText.slice(0, 80)}…` : paraText;
		head.appendChild(el("div", "pc-quote", excerpt));
		const closeBtn = el("button", "pc-close");
		closeBtn.type = "button";
		closeBtn.setAttribute("aria-label", T.close);
		closeBtn.innerHTML = ICON_CLOSE;
		closeBtn.addEventListener("click", closePanel);
		head.appendChild(closeBtn);

		openCountLine = el(
			"div",
			"pc-count-line",
			countText((counts && counts[anchor]) || 0),
		);

		const list = el("div", "pc-list");
		if (commentsCache) {
			renderCommentsInto(list, anchor);
		} else {
			list.appendChild(el("div", "pc-status", "…"));
		}

		const form = el("form", "pc-form");
		form.appendChild(el("div", "pc-form-title", T.postComment));
		const nick = el("input", "pc-input");
		nick.type = "text";
		nick.name = "nick";
		nick.required = true;
		nick.maxLength = 40;
		nick.placeholder = T.nickname;
		nick.setAttribute("aria-label", T.nickname);
		const contact = el("input", "pc-input");
		contact.type = "text";
		contact.name = "contact";
		contact.maxLength = 100;
		contact.placeholder = T.contact;
		contact.setAttribute("aria-label", T.contact);
		const content = el("textarea", "pc-input pc-textarea");
		content.name = "content";
		content.required = true;
		content.maxLength = 2000;
		content.placeholder = T.writeComment;
		content.setAttribute("aria-label", T.writeComment);
		// Honeypot: hidden from humans via CSS, submitted as-is. Bots that
		// fill it in get dropped server-side.
		const hp = el("input", "pc-hp");
		hp.type = "text";
		hp.name = "website";
		hp.tabIndex = -1;
		hp.setAttribute("autocomplete", "off");
		hp.setAttribute("aria-hidden", "true");
		const error = el("div", "pc-error");
		error.setAttribute("role", "alert");
		const submit = el("button", "pc-submit", T.submit);
		submit.type = "submit";
		form.append(nick, contact, content, hp, error, submit);

		panelEl.append(head, openCountLine, list, form);
		document.body.append(overlayEl, panelEl);
		document.body.style.overflow = "hidden";
		// start off-canvas, then transition in
		requestAnimationFrame(() => {
			if (overlayEl) overlayEl.classList.add("pc-open");
			if (panelEl) panelEl.classList.add("pc-open");
		});

		// prefill identity from previous comments
		try {
			nick.value = localStorage.getItem("pc:nick") || "";
			contact.value = localStorage.getItem("pc:contact") || "";
		} catch {}

		nick.focus();

		ensureComments().then((ok) => {
			if (myGen !== gen || openAnchor !== anchor || !panelEl) return;
			if (!ok) {
				list.innerHTML = "";
				list.appendChild(el("div", "pc-status", T.loadFailed));
				return;
			}
			renderCommentsInto(list, anchor);
		});

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			if (submit.disabled) return;
			error.textContent = "";
			error.classList.remove("pc-show");
			const showErr = (msg) => {
				error.textContent = msg;
				error.classList.add("pc-show");
			};
			const payload = {
				path: window.location.pathname,
				anchor,
				nick: nick.value.trim(),
				content: content.value.trim(),
				website: hp.value || "",
			};
			if (contact.value.trim()) payload.contact = contact.value.trim();
			if (!payload.nick || !payload.content) return;
			submit.disabled = true;
			try {
				const res = await fetch(`${API_BASE}/comments`, {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					credentials: "omit",
					body: JSON.stringify(payload),
				});
				const data = await res.json().catch(() => null);
				if (myGen !== gen) return;
				if (res.ok && data && data.ok) {
					// optimistic append
					const comment = {
						id: data.id,
						nick: payload.nick,
						content: payload.content,
						pid: null,
						created_at: Date.now(),
					};
					if (!commentsCache) commentsCache = {};
					if (!commentsCache[anchor]) commentsCache[anchor] = [];
					commentsCache[anchor].push(comment);
					counts = counts || {};
					counts[anchor] = (counts[anchor] || 0) + 1;
					updateBadge(anchor);
					renderCommentsInto(list, anchor);
					list.scrollTop = list.scrollHeight;
					content.value = "";
					try {
						localStorage.setItem("pc:nick", payload.nick);
						localStorage.setItem("pc:contact", contact.value.trim());
					} catch {}
				} else if (res.status === 429) {
					showErr(T.tooFast);
				} else {
					showErr(T.networkError);
				}
			} catch {
				if (myGen === gen) showErr(T.networkError);
			} finally {
				submit.disabled = false;
			}
		});
	}

	// ---------------------------------------------------------------------
	// Init: (re)anchor the current page's paragraphs and fetch counts.
	// No-op off post pages (anything without .markdown-content).
	// ---------------------------------------------------------------------
	function initParaComments() {
		closePanel();
		gen++;
		counts = null;
		commentsCache = null;
		commentsPromise = null;
		btnByAnchor = new Map();
		pageLang = docLang();
		T = STRINGS[pageLang] || STRINGS.en;
		detectScopeAttr();

		const root = document.querySelector(".markdown-content");
		if (!root) return;

		// make a same-DOM re-run idempotent
		for (const btn of root.querySelectorAll(".pc-btn")) btn.remove();

		const SKIP = ".ec-frame, code, pre, .admonition, blockquote, figure, table";
		const seen = new Map();
		const path = window.location.pathname;

		for (const p of root.querySelectorAll("p")) {
			if (p.closest(SKIP)) continue;
			const text = normalize(p.textContent || "");
			if (text.length < 8) continue;
			const base = fnv1a(text);
			const n = (seen.get(base) || 0) + 1;
			seen.set(base, n);
			const anchor = n === 1 ? base : `${base}~${n}`;
			p.setAttribute("data-pc-anchor", anchor);
			p.classList.add("pc-para");
			stamp(p);

			const btn = el("button", "pc-btn");
			btn.type = "button";
			btn.setAttribute("aria-label", T.commentPara);
			btn.title = T.commentPara;
			btn.innerHTML = ICON_COMMENT;
			btn.addEventListener("click", (e) => {
				e.preventDefault();
				openPanel(anchor, text);
			});
			p.appendChild(btn);
			btnByAnchor.set(anchor, btn);
		}

		// counts are best-effort: on failure badges simply stay hidden
		const myGen = gen;
		fetch(`${API_BASE}/counts?path=${encodeURIComponent(path)}`, {
			credentials: "omit",
		})
			.then((res) => (res.ok ? res.json() : null))
			.then((data) => {
				if (myGen !== gen || !data) return;
				counts = data;
				for (const anchor of Object.keys(counts)) updateBadge(anchor);
			})
			.catch(() => {});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initParaComments);
	} else {
		initParaComments();
	}

	// Swup swaps only the main/#toc containers without re-running page
	// scripts, so re-init on every navigation. Register the hook exactly
	// once and wait for window.swup if needed. Document-level listeners are
	// likewise bound once; per-paragraph buttons are recreated each init.
	const w = window;
	if (!w.__paraCommentsDocBound) {
		w.__paraCommentsDocBound = true;
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape") closePanel();
		});
	}
	if (!w.__paraCommentsSwupHooked) {
		w.__paraCommentsSwupHooked = true;
		const tryHook = (n = 0) => {
			if (w.swup?.hooks) {
				w.swup.hooks.on("page:view", initParaComments);
			} else if (n < 50) {
				setTimeout(() => tryHook(n + 1), 100);
			}
		};
		tryHook();
	}
</script>

<style>
	/* --- per-paragraph button + badge ---------------------------------- */
	.pc-para {
		position: relative;
		padding-right: 1.75rem;
	}
	.pc-btn {
		position: absolute;
		top: 0.15rem;
		right: 0;
		width: 1.5rem;
		height: 1.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: none;
		border-radius: 0.375rem;
		background: transparent;
		color: rgba(0, 0, 0, 0.4);
		cursor: pointer;
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.15s ease,
			background 0.15s ease,
			color 0.15s ease;
	}
	.pc-para:hover .pc-btn,
	.pc-para:focus-within .pc-btn,
	.pc-btn.pc-btn--has {
		opacity: 1;
		pointer-events: auto;
	}
	.pc-btn:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}
	.pc-btn:active {
		background: var(--btn-plain-bg-active);
	}
	html.dark .pc-btn {
		color: rgba(255, 255, 255, 0.4);
	}
	html.dark .pc-btn:hover {
		color: var(--primary);
	}
	.pc-badge {
		position: absolute;
		top: -0.45rem;
		right: -0.55rem;
		min-width: 1rem;
		height: 1rem;
		padding: 0 0.25rem;
		border-radius: 0.5rem;
		background: var(--primary);
		color: #fff;
		font-size: 0.625rem;
		line-height: 1rem;
		text-align: center;
		pointer-events: none;
	}

	/* --- overlay + slide-over panel ------------------------------------- */
	.pc-overlay {
		position: fixed;
		inset: 0;
		z-index: 210;
		background: rgba(0, 0, 0, 0.35);
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.pc-overlay.pc-open {
		opacity: 1;
	}
	.pc-panel {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		z-index: 220;
		width: 380px;
		max-width: 100vw;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem;
		background: var(--card-bg);
		border-left: 1px solid var(--line-divider);
		border-radius: var(--radius-large) 0 0 var(--radius-large);
		box-shadow: -0.5rem 0 2rem rgba(0, 0, 0, 0.15);
		transform: translateX(105%);
		transition: transform 0.25s ease;
	}
	.pc-panel.pc-open {
		transform: translateX(0);
	}
	@media (max-width: 767px) {
		.pc-panel {
			top: auto;
			left: 0;
			width: auto;
			max-height: 70vh;
			border-left: none;
			border-top: 1px solid var(--line-divider);
			border-radius: var(--radius-large) var(--radius-large) 0 0;
			box-shadow: 0 -0.5rem 2rem rgba(0, 0, 0, 0.15);
			transform: translateY(105%);
		}
		.pc-panel.pc-open {
			transform: translateY(0);
		}
	}

	/* --- panel content -------------------------------------------------- */
	.pc-panel-head {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
	}
	.pc-quote {
		flex: 1;
		padding-left: 0.625rem;
		border-left: 3px solid var(--primary);
		font-size: 0.875rem;
		line-height: 1.5;
		color: rgba(0, 0, 0, 0.55);
		overflow-wrap: break-word;
	}
	html.dark .pc-quote {
		color: rgba(255, 255, 255, 0.55);
	}
	.pc-close {
		flex: none;
		width: 1.75rem;
		height: 1.75rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: none;
		border-radius: 0.375rem;
		background: transparent;
		color: rgba(0, 0, 0, 0.5);
		cursor: pointer;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}
	.pc-close:hover {
		background: var(--btn-plain-bg-hover);
